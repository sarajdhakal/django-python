{
  "info": {
    "name": "Expense Tracker API",
    "description": "Collection covering all endpoints of the Expense Tracker API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    }
  ],
  "item": [
    {
      "name": "List Categories",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/categories/",
          "host": ["{{base_url}}"],
          "path": ["api", "categories", ""]
        },
        "description": "Returns all categories."
      }
    },
    {
      "name": "Create Category",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Groceries\",\n  \"description\": \"Food and household supplies\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/categories/",
          "host": ["{{base_url}}"],
          "path": ["api", "categories", ""]
        },
        "description": "Creates a new category."
      }
    },
    {
      "name": "List Expenses",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/expenses/?start_date=2026-01-01&end_date=2026-12-31",
          "host": ["{{base_url}}"],
          "path": ["api", "expenses", ""],
          "query": [
            { "key": "start_date", "value": "2026-01-01" },
            { "key": "end_date", "value": "2026-12-31" }
          ]
        },
        "description": "Lists all expenses. Optionally filter by start_date and end_date (YYYY-MM-DD)."
      }
    },
    {
      "name": "Create Expense",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Weekly shop\",\n  \"amount\": \"54.20\",\n  \"category\": 1,\n  \"date\": \"2026-06-09\",\n  \"notes\": \"Supermarket run\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/expenses/",
          "host": ["{{base_url}}"],
          "path": ["api", "expenses", ""]
        },
        "description": "Creates a new expense."
      }
    },
    {
      "name": "Retrieve Expense",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/expenses/1/",
          "host": ["{{base_url}}"],
          "path": ["api", "expenses", "1", ""]
        },
        "description": "Retrieves a single expense by id."
      }
    },
    {
      "name": "Update Expense",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Weekly shop (updated)\",\n  \"amount\": \"60.00\",\n  \"category\": 1,\n  \"date\": \"2026-06-09\",\n  \"notes\": \"Adjusted total\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/expenses/1/",
          "host": ["{{base_url}}"],
          "path": ["api", "expenses", "1", ""]
        },
        "description": "Updates an existing expense by id."
      }
    },
    {
      "name": "Delete Expense",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/expenses/1/",
          "host": ["{{base_url}}"],
          "path": ["api", "expenses", "1", ""]
        },
        "description": "Deletes an expense by id."
      }
    },
    {
      "name": "Expense Summary",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/expenses/summary/",
          "host": ["{{base_url}}"],
          "path": ["api", "expenses", "summary", ""]
        },
        "description": "Returns the total amount spent per category, converted to BASE_CURRENCY (Currency conversion feature)."
      }
    },
    {
      "name": "Create Category (with monthly budget)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Dining\",\n  \"description\": \"Restaurants and takeout\",\n  \"monthly_limit\": \"200.00\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/categories/",
          "host": ["{{base_url}}"],
          "path": ["api", "categories", ""]
        },
        "description": "Bot alerts feature: creates a category with a monthly spending limit. Crossing it triggers a bot alert."
      }
    },
    {
      "name": "Create Expense (with currency)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Hotel in Paris\",\n  \"amount\": \"120.00\",\n  \"currency\": \"EUR\",\n  \"category\": 1,\n  \"date\": \"2026-06-09\",\n  \"notes\": \"Two nights\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/expenses/",
          "host": ["{{base_url}}"],
          "path": ["api", "expenses", ""]
        },
        "description": "Currency conversion feature: creates an expense in a non-base currency. The summary endpoint converts it to BASE_CURRENCY."
      }
    }
  ]
}
